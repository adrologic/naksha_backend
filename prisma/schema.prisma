// Naksha CMS schema — Phase 2
// Covers: site content entities, page documents with block-based layouts,
// site-wide globals, central media library, slug-rename redirects, contact form.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Media library (central image store, mirrors Cloudinary) ──────────────────
model MediaAsset {
  id        String   @id @default(cuid())
  publicId  String   @unique // cloudinary public_id
  url       String
  secureUrl String
  format    String?
  width     Int?
  height    Int?
  bytes     Int?
  alt       String   @default("")
  tags      String[] @default([])
  folder    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Content collections ──────────────────────────────────────────────────────
model Project {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  market            String
  location          String
  year              Int
  client            String?
  size              String?
  duration          String?
  summary           String
  description       String   @default("")
  coverImage        String?
  coverImageAlt     String?
  gallery           Json     @default("[]") // [{ url, alt }]
  highlights        Json     @default("[]") // string[]
  seoTitle             String?
  seoDescription       String?
  seoOgImage           String?
  seoKeywords          Json     @default("[]") // string[] — legacy, kept for 1 release
  seoPrimaryKeyword    String?
  seoSecondaryKeywords Json     @default("[]") // string[]
  seoOgTitle           String?
  seoOgDescription     String?
  seoCanonicalUrl      String?
  seoNoIndex           Boolean  @default(false)
  seoNoFollow          Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Service {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  summary           String
  icon              String?
  iconAlt           String?
  bullets              Json     @default("[]") // string[]
  body                 String   @default("")
  seoTitle             String?
  seoDescription       String?
  seoOgImage           String?
  seoKeywords          Json     @default("[]") // string[] — legacy, kept for 1 release
  seoPrimaryKeyword    String?
  seoSecondaryKeywords Json     @default("[]") // string[]
  seoOgTitle           String?
  seoOgDescription     String?
  seoCanonicalUrl      String?
  seoNoIndex           Boolean  @default(false)
  seoNoFollow          Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Article {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  excerpt           String
  body              String   @default("")
  cover             String?
  coverAlt          String?
  author            String
  category          String?
  publishedAt          DateTime @default(now())
  seoTitle             String?
  seoDescription       String?
  seoOgImage           String?
  seoKeywords          Json     @default("[]") // string[] — legacy, kept for 1 release
  seoPrimaryKeyword    String?
  seoSecondaryKeywords Json     @default("[]") // string[]
  seoOgTitle           String?
  seoOgDescription     String?
  seoCanonicalUrl      String?
  seoNoIndex           Boolean  @default(false)
  seoNoFollow          Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Leader {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  role              String
  bio               String   @default("")
  portrait             String?
  portraitAlt          String?
  seoTitle             String?
  seoDescription       String?
  seoOgImage           String?
  seoKeywords          Json     @default("[]") // string[] — legacy, kept for 1 release
  seoPrimaryKeyword    String?
  seoSecondaryKeywords Json     @default("[]") // string[]
  seoOgTitle           String?
  seoOgDescription     String?
  seoCanonicalUrl      String?
  seoNoIndex           Boolean  @default(false)
  seoNoFollow          Boolean  @default(false)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  city      String
  address   Json     @default("[]") // string[]
  phone     String?
  email     String?
  image     String?
  imageAlt  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  role      String?
  company   String?
  avatar    String?
  avatarAlt String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Page documents (block-based layouts) ─────────────────────────────────────
// One row per route. `blocks` is an ordered array of block objects rendered
// by the website. Block schemas live in code, not the DB, so admin can add/
// reorder/remove blocks freely without migrations.
model Page {
  id                    String   @id @default(cuid())
  key                   String   @unique // "home", "about", "services-index", ...
  path                  String   @unique // "/", "/about", "/services"
  title                 String
  blocks                Json     @default("[]")
  // Core SEO
  seoTitle              String?
  seoDescription        String?
  seoOgImage            String?
  // Advanced SEO
  seoKeywords           String?  // comma-separated — legacy, kept for 1 release
  seoPrimaryKeyword     String?
  seoSecondaryKeywords  String?  // comma-separated
  seoRobots             String?  // e.g. "index,follow" or "noindex,nofollow"
  seoCanonical          String?  // override canonical URL
  // Open Graph (overrides the seo* values when set)
  ogTitle               String?
  ogDescription         String?
  ogType                String?  // "website", "article", ...
  // Twitter card
  twitterCard           String?  // "summary" | "summary_large_image"
  twitterTitle          String?
  twitterDescription    String?
  twitterImage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ── Globals (site-wide singletons: navbar, footer, settings) ─────────────────
model Global {
  id        String   @id @default(cuid())
  key       String   @unique // "navbar", "footer", "siteSettings"
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Redirects (auto-created when a slug is renamed) ──────────────────────────
model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
}

// ── Path-based SEO overrides (separate from CMS Page documents) ─────────────
// One row per URL path the admin wants to control SEO for, including routes
// that don't have a CMS Page document (e.g. /services, /contact, /legal/*).
model SeoPage {
  id              String   @id @default(cuid())
  path              String   @unique
  title             String?
  description       String?
  keywords          Json     @default("[]") // string[] — legacy, kept for 1 release
  primaryKeyword    String?
  secondaryKeywords Json     @default("[]") // string[]
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean  @default(false)
  noFollow        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Contact form submissions ─────────────────────────────────────────────────
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())
}
