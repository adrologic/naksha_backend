# Copy to .env and fill in real values

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins (no trailing slash, include scheme)
# Local: ports 3000 (site), 3001 (admin), 4001 (extra)
# Production (Coolify): set CORS_ORIGIN to your Vercel URLs, e.g.
#   CORS_ORIGIN=https://your-site.vercel.app,https://your-admin.vercel.app,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:4001,http://localhost:4002

# Postgres (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# On-demand revalidation — when set, backend POSTs to website after every mutation
# so admin edits appear on the public site within seconds.
#   WEBSITE_REVALIDATE_URL: full URL of the website's revalidate route
#   REVALIDATE_SECRET:      shared secret (must match the value set on the website)
WEBSITE_REVALIDATE_URL=https://naksha-construction-website.vercel.app/api/revalidate
REVALIDATE_SECRET=

# Admin login (single admin user)
#   ADMIN_EMAIL          the login email
#   ADMIN_PASSWORD_HASH  scrypt hash — generate with:
#                          npx tsx scripts/hash-password.ts '<password>'
#   ADMIN_PASSWORD       plaintext alternative for local dev only; ignored when
#                        ADMIN_PASSWORD_HASH is set
#   AUTH_SECRET          >=32 random chars used to sign session tokens. Changing
#                        it logs everyone out.
# If these are unset the API still serves public reads, but every write is
# rejected with 401 and /auth/login returns 503.
ADMIN_EMAIL=admin@naksha.com
ADMIN_PASSWORD_HASH=
AUTH_SECRET=
AUTH_TOKEN_TTL_HOURS=12
